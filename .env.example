# ---------------------------------------------------------------------------
# LLM Cost Anomaly Detector — example config. Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# --- database ---
# Inside docker-compose the host is `db`; for local dev use `localhost`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/costmonitor

# --- dashboard -> api ---
API_URL=http://api:8000

# --- secrets ---
# Only needed to generate realistic synthetic traffic with `--live`.
OPENAI_API_KEY=
# Optional: incidents are POSTed here when set. Leave blank to disable.
SLACK_WEBHOOK_URL=

# --- detection thresholds (tunable without code changes) ---
Z_SCORE_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
MIN_SAMPLES=8
LOOP_COUNT_THRESHOLD=10
LOOP_WINDOW_SECONDS=60
COST_SPIKE_BUCKET_SECONDS=60
BASELINE_WINDOW_SECONDS=3600
TOKEN_GROWTH_RATIO=3.0
COOLDOWN_SECONDS=300
